<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net461</TargetFramework>
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Waveplus.DaqSys">
      <HintPath>lib\Waveplus.DaqSys.dll</HintPath>
      <Private>true</Private>
    </Reference>

    <Reference Include="Waveplus.DaqSysInterface">
      <HintPath>lib\Waveplus.DaqSysInterface.dll</HintPath>
      <Private>true</Private>
    </Reference>

    <Reference Include="CyUSB">
      <HintPath>lib\CyUSB.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="lib\Waveplus.DaqSys.pdb">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>

    <None Include="lib\Waveplus.DaqSysInterface.pdb">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>